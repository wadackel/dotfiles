{
  "$schema": "https://opencode.ai/config.json",

  // OpenCode Go (https://opencode.ai/docs/go/)
  // 認証は `opencode auth login` または TUI 内 /connect で実施する必要あり。
  // provider prefix は実機の `opencode models` 出力に合わせて `opencode/`。
  "model": "opencode/deepseek-v4-pro",
  "small_model": "opencode/qwen3.5-plus",

  // tmux picker (prefix+w) bridges opencode session events → tmux pane
  // options. Source lives in dotfiles/home/programs/opencode/plugin.ts;
  // home-manager symlinks it to ~/.config/opencode/plugin.ts. The path must
  // be absolute (file:// URL) — opencode 1.14.30 resolves relative `./` paths
  // against CWD, not opencode.json's directory, and treats them as npm-style
  // package directories looking for package.json. {env:HOME} is opencode's
  // own template substitution and is profile-independent.
  "plugin": [
    "file://{env:HOME}/.config/opencode/plugin.ts",
    "file://{env:HOME}/.config/opencode/plugins/rtk.ts"
  ],

  // AGENTS.md は ~/.claude/CLAUDE.md がフォールバック読み込みされるため未設定。
  // RTK ガイドだけ追加で読ませる。{env:HOME} は profile 非依存の置換。
  "instructions": [
    "{env:HOME}/.claude/RTK.md"
  ],

  // 信頼ベース: 編集・bash・webfetch は基本 allow、破壊的コマンドのみ deny。
  // opencode は最後に一致したルールが優先されるため、deny を後ろに置く。
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "allow",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf .git": "deny",
      "sudo rm *": "deny",
      "sudo dd *": "deny",
      "sudo mkfs *": "deny",
      "sudo fdisk *": "deny",
      "sudo chmod 777 *": "deny",
      "sudo chown *": "deny",
      "sudo *passwd*": "deny",
      "sudo *shadow*": "deny",
      "dd *": "deny",
      "mkfs *": "deny",
      "fdisk *": "deny",
      "git push --force-with-lease origin main": "deny",
      "git push -f origin main": "deny",
      "npm publish *": "deny",
      "pnpm publish *": "deny",
      "yarn publish *": "deny",
      "deno publish *": "deny",
      "cargo publish *": "deny",
      "docker system prune -af": "deny"
    },
    "skill": {
      "*": "allow"
    }
  },

  // 自動更新は Claude 側 (DISABLE_AUTOUPDATER=1) と方針を揃える
  "autoupdate": false,

  // 会話共有はデフォルトで無効
  "share": "disabled"
}
